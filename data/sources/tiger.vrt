    </SrcSQL>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbLineString</GeometryType>
  </OGRVRTLayer>

  <OGRVRTLayer name="rails">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/TIGER2024/RAILS/tl_2024_us_rails.zip/tl_2024_us_rails.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT LINEARID AS linear_id, FULLNAME AS full_name, MTFCC AS maftiger_code
