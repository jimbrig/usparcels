<OGRVRTDataSource>

  <!-- STATES -->
  <OGRVRTLayer name="tiger_states">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_state_20m.zip/cb_2024_us_state_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT
        GEOID AS geoid,
        GEOIDFQ AS geoidfq,
        STATEFP AS state_fips,
        STATENS AS state_gnis,
        STUSPS AS state_abbr,
        NAME AS state_name,
        LSAD AS lsad_code,
        ALAND AS area_land_m2,
        AWATER AS area_water_m2
      FROM cb_2024_us_state_20m
      WHERE STATEFP NOT IN ('02','15','60','66','69','72','74','78')
    </SrcSQL>
    <SrcRegion>POLYGON((-125 24,-66 24,-66 50,-125 50,-125 24))</SrcRegion>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbMultiPolygon</GeometryType>
  </OGRVRTLayer>


  <OGRVRTLayer name="nation">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_nation_20m.zip/cb_2024_us_nation_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, NAME AS nation_name
      FROM cb_2024_us_nation_20m
    </SrcSQL>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbMultiPolygon</GeometryType>
  </OGRVRTLayer>

  <OGRVRTLayer name="region">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_region_20m.zip/cb_2024_us_region_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, REGIONCE AS region_code,
             NAME AS region_name, NAMELSAL AS lsad_name, LSAD AS lsad_code,
             ALAND AS area_land_m2, AWATER AS area_water_m2
      FROM cb_2024_us_region_20m
    </SrcSQL>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbMultiPolygon</GeometryType>
  </OGRVRTLayer>

  <OGRVRTLayer name="division">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_division_20m.zip/cb_2024_us_division_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, DIVISIONCE AS division_code,
             NAME AS division_name, NAMELSAL AS lsad_name, LSAD AS lsad_code,
             ALAND AS area_land_m2, AWATER AS area_water_m2
      FROM cb_2024_us_division_20m
    </SrcSQL>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbMultiPolygon</GeometryType>
  </OGRVRTLayer>

  <OGRVRTLayer name="county">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_county_20m.zip/cb_2024_us_county_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, STATEFP AS state_fips,
             CONCAT(STATEFP, COUNTYFP) AS county_fips, COUNTYNSL AS county_gnis,
             NAME AS county_name, NAMELSAL AS lsad_name, LSAD AS lsad_code,
             ALAND AS area_land_m2, AWATER AS area_water_m2
      FROM cb_2024_us_county_20m
      WHERE STATEFP NOT IN ('02','15','60','66','69','72','74','78')
    </SrcSQL>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbMultiPolygon</GeometryType>
  </OGRVRTLayer>

  <OGRVRTLayer name="csa">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_csa_20m.zip/cb_2024_us_csa_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, CSAFP AS csa_fips,
             NAME AS csa_name, NAMELSAL AS lsad_name, LSAD AS lsad_code,
             ALAND AS area_land_m2, AWATER AS area_water_m2
      FROM cb_2024_us_csa_20m
    </SrcSQL>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbMultiPolygon</GeometryType>
  </OGRVRTLayer>

  <OGRVRTLayer name="cbsa">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_cbsa_20m.zip/cb_2024_us_cbsa_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, CSAFP AS csa_fips,
