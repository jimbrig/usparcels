  </OGRVRTLayer>

  <OGRVRTLayer name="metdiv">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_metdiv_20m.zip/cb_2024_us_metdiv_20m.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, CSAFP AS csa_fips,
             CBSAFP AS cbsa_fips, METDIVFP AS metdiv_fips, NAME AS metdiv_name,
             NAMELSAL AS lsad_name, LSAD AS lsad_code,
