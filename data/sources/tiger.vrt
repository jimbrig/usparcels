             LSAD AS lsad_code, ALAND AS area_land_m2, AWATER AS area_water_m2
      FROM cb_2024_us_cbsa_20m
    </SrcSQL>
    <LayerSRS>EPSG:4326</LayerSRS>
    <GeometryType>wkbMultiPolygon</GeometryType>
  </OGRVRTLayer>

  <OGRVRTLayer name="cousub">
    <SrcDataSource>/vsizip//vsicurl/https://www2.census.gov/geo/tiger/GENZ2024/shp/cb_2024_us_cousub_500k.zip/cb_2024_us_cousub_500k.shp</SrcDataSource>
    <SrcSQL dialect="OGRSQL">
      SELECT GEOID AS geoid, GEOIDFQ AS geoidfq, STATEFP AS state_fips,
             CONCAT(STATEFP, COUNTYFP) AS county_fips, COUSUBFP AS cousub_fips,
             COUSUBNS AS cousub_gnis, NAME AS cousub_name, NAMELSAL AS lsad_name,
             LSAD AS lsad_code, ALAND AS area_land_m2, AWATER AS area_water_m2
